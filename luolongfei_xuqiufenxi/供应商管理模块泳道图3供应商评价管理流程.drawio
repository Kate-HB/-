<mxfile host="Electron" agent="Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) draw.io/29.6.6 Chrome/144.0.7559.236 Electron/40.8.4 Safari/537.36" version="29.6.6">
  <diagram id="SupplierEvaluationFlow" name="供应商评价管理流程">
    <mxGraphModel dx="2102" dy="1347" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="title" parent="1" style="whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1" value="供应商评价管理流程" vertex="1">
          <mxGeometry height="710" width="35" x="25" y="40" as="geometry" />
        </mxCell>
        <mxCell id="lane1" parent="1" style="swimlane;fontSize=14;horizontal=0;swimlaneFillColor=#f5f5f5;" value="采购/运营人员" vertex="1">
          <mxGeometry height="190" width="1030" x="60" y="40" as="geometry" />
        </mxCell>
        <mxCell id="start" parent="lane1" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="35" width="35" x="60" y="55" as="geometry" />
        </mxCell>
        <mxCell id="step1" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="采购/运营人员填写供应商评价&#xa;（交货及时性、质量合格率、配合度、服务态度、价格合理性等）" vertex="1">
          <mxGeometry height="65" width="300" x="140" y="40" as="geometry" />
        </mxCell>
        <mxCell id="submit" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="提交供应商评价" vertex="1">
          <mxGeometry height="45" width="130" x="580" y="70" as="geometry" />
        </mxCell>
        <mxCell id="modify" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="修改评价内容" vertex="1">
          <mxGeometry height="45" width="170" x="40" y="125" as="geometry" />
        </mxCell>
        <mxCell id="lane2" parent="1" style="swimlane;fontSize=14;horizontal=0;swimlaneFillColor=#f5f5f5;" value="系统" vertex="1">
          <mxGeometry height="190" width="1030" x="60" y="250" as="geometry" />
        </mxCell>
        <mxCell id="step2" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统自动计算评价分数&#xa;并更新供应商综合评分" vertex="1">
          <mxGeometry height="55" width="260" x="140" y="70" as="geometry" />
        </mxCell>
        <mxCell id="decision1" parent="lane2" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" value="评价是否完整有效？" vertex="1">
          <mxGeometry height="70" width="120" x="450" y="62.5" as="geometry" />
        </mxCell>
        <mxCell id="step3" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统记录评价日志&#xa;并通知审核主管" vertex="1">
          <mxGeometry height="50" width="220" x="590" y="135" as="geometry" />
        </mxCell>
        <mxCell id="final" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统更新供应商评价记录&#xa;同步到供应商综合评分&#xa;记录评价历史" vertex="1">
          <mxGeometry height="70" width="230" x="780" y="55" as="geometry" />
        </mxCell>
        <mxCell id="end" parent="lane2" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="35" width="35" x="877.5" as="geometry" />
        </mxCell>
        <mxCell id="e14" edge="1" parent="lane2" source="final" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;" target="end" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lane3" parent="1" style="swimlane;fontSize=14;horizontal=0;swimlaneFillColor=#f5f5f5;" value="审核主管" vertex="1">
          <mxGeometry height="290" width="1030" x="60" y="460" as="geometry" />
        </mxCell>
        <mxCell id="review" parent="lane3" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="审核主管审核供应商评价&#xa;（检查评价客观性、是否有重大偏差）" vertex="1">
          <mxGeometry height="60" width="290" x="130" y="72.5" as="geometry" />
        </mxCell>
        <mxCell id="decision2" parent="lane3" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" value="审核是否通过？" vertex="1">
          <mxGeometry height="70" width="115" x="450" y="68" as="geometry" />
        </mxCell>
        <mxCell id="reject" parent="lane3" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="填写驳回意见并退回修改" vertex="1">
          <mxGeometry height="50" width="170" x="420" y="215" as="geometry" />
        </mxCell>
        <mxCell id="approve" parent="lane3" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="确认审核通过" vertex="1">
          <mxGeometry height="45" width="150" x="600" y="80" as="geometry" />
        </mxCell>
        <mxCell id="e1" edge="1" parent="1" source="start" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;" target="step1" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="e2" edge="1" parent="1" source="step1" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;exitX=0.657;exitY=0.973;exitDx=0;exitDy=0;exitPerimeter=0;" target="step2" value="">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
