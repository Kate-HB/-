          <mxGeometry height="720" width="35" x="25" y="40" as="geometry" />
        </mxCell>
        <mxCell id="lane1" parent="1" style="swimlane;fontSize=14;horizontal=0;swimlaneFillColor=#f5f5f5;" value="采购/运营人员" vertex="1">
