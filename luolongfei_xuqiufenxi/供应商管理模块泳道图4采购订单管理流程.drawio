        </mxCell>
        <mxCell id="submit" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="提交采购订单审核" vertex="1">
          <mxGeometry height="45" width="140" x="580" y="70" as="geometry" />
        </mxCell>
        <mxCell id="lane2" parent="1" style="swimlane;fontSize=14;horizontal=0;swimlaneFillColor=#f5f5f5;" value="系统" vertex="1">
          <mxGeometry height="190" width="1040" x="60" y="260" as="geometry" />
        </mxCell>
        <mxCell id="step2" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统自动校验采购订单&#xa;（库存可用性、供应商合同有效性、预算检查、价格合理性）" vertex="1">
          <mxGeometry height="65" width="290" x="130" y="70" as="geometry" />
        </mxCell>
        <mxCell id="decision1" parent="lane2" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" value="系统校验是否通过？" vertex="1">
          <mxGeometry height="70" width="120" x="450" y="67.5" as="geometry" />
        </mxCell>
        <mxCell id="step3" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统记录订单日志并通知审核主管" vertex="1">
          <mxGeometry height="50" width="230" x="590" y="135" as="geometry" />
        </mxCell>
        <mxCell id="final" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统生成正式采购订单编号&#xa;更新订单状态为“已审批”&#xa;通知供应商并同步库存预期" vertex="1">
          <mxGeometry height="75" width="240" x="780" y="57.5" as="geometry" />
        </mxCell>
        <mxCell id="end" parent="lane2" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="35" width="35" x="882.5" as="geometry" />
        </mxCell>
        <mxCell id="e14" edge="1" parent="lane2" source="final" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;" target="end" value="">
