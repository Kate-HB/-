        </mxCell>
        <mxCell id="step1" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="采购人员创建采购订单&#xa;（选择供应商、商品、数量、单价、交货日期、付款方式等）" vertex="1">
          <mxGeometry height="70" width="310" x="130" y="40" as="geometry" />
        </mxCell>
        <mxCell id="modify" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="修改采购订单" vertex="1">
