          <mxGeometry height="290" width="1040" x="60" y="470" as="geometry" />
        </mxCell>
        <mxCell id="review" parent="lane3" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="审核主管审核采购订单&#xa;（订单必要性、价格合理性、预算合规、供应商资质）" vertex="1">
          <mxGeometry height="65" width="290" x="130" y="70" as="geometry" />
