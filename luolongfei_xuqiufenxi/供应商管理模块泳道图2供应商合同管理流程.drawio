        <mxCell id="title" parent="1" style="whiteSpace=wrap;html=1;align=center;verticalAlign=middle;fontSize=22;fontStyle=1" value="供应商合同管理流程" vertex="1">
          <mxGeometry height="710" width="35" x="25" y="40" as="geometry" />
        </mxCell>
        <mxCell id="lane1" parent="1" style="swimlane;fontSize=14;horizontal=0;swimlaneFillColor=#f5f5f5;" value="采购/运营人员" vertex="1">
