        </mxCell>
        <mxCell id="step1" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="采购人员起草或上传供应商合同&#xa;（合同类型、有效期、价格条款、交货条款、付款条件、违约责任等）" vertex="1">
          <mxGeometry height="65" width="290" x="140" y="40" as="geometry" />
        </mxCell>
        <mxCell id="modify" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="修改合同内容" vertex="1">
          <mxGeometry height="45" width="170" x="60" y="125" as="geometry" />
        </mxCell>
        <mxCell id="submit" parent="lane1" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="提交合同审核" vertex="1">
          <mxGeometry height="45" width="130" x="580" y="70" as="geometry" />
        </mxCell>
        <mxCell id="lane2" parent="1" style="swimlane;fontSize=14;horizontal=0;swimlaneFillColor=#f5f5f5;" value="系统" vertex="1">
          <mxGeometry height="190" width="1010" x="60" y="250" as="geometry" />
        </mxCell>
        <mxCell id="step2" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统自动校验合同基本信息&#xa;（完整性、日期有效性、与供应商关联检查）" vertex="1">
          <mxGeometry height="55" width="270" x="140" y="72.5" as="geometry" />
        </mxCell>
        <mxCell id="decision1" parent="lane2" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" value="系统校验是否通过？" vertex="1">
          <mxGeometry height="70" width="115" x="440" y="65" as="geometry" />
        </mxCell>
        <mxCell id="step3" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统记录提交日志并通知审核主管/法务" vertex="1">
          <mxGeometry height="50" width="230" x="590" y="135" as="geometry" />
        </mxCell>
        <mxCell id="final" parent="lane2" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="系统归档合同&#xa;生成合同编号&#xa;更新合同状态为“生效”&#xa;设置到期提醒" vertex="1">
          <mxGeometry height="75" width="230" x="770" y="50" as="geometry" />
        </mxCell>
        <mxCell id="end" parent="lane2" style="ellipse;whiteSpace=wrap;html=1;fillColor=none;strokeColor=#000000;" value="" vertex="1">
          <mxGeometry height="35" width="35" x="867.5" as="geometry" />
        </mxCell>
        <mxCell id="e14" edge="1" parent="lane2" source="final" style="edgeStyle=orthogonalEdgeStyle;endArrow=classic;html=1;" target="end" value="">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="lane3" parent="1" style="swimlane;fontSize=14;horizontal=0;swimlaneFillColor=#f5f5f5;" value="审核主管 / 法务" vertex="1">
          <mxGeometry height="290" width="1010" x="60" y="460" as="geometry" />
        </mxCell>
        <mxCell id="review" parent="lane3" style="rounded=1;whiteSpace=wrap;html=1;fontSize=12;" value="审核主管/法务审核合同&#xa;（条款合法性、风险评估、与公司政策一致性）" vertex="1">
          <mxGeometry height="65" width="290" x="140" y="70" as="geometry" />
        </mxCell>
        <mxCell id="decision2" parent="lane3" style="rhombus;whiteSpace=wrap;html=1;fontSize=12;" value="合同审核是否通过？" vertex="1">
